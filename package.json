{
  "name": "tech-learning-space",
  "private": true,
  "version": "1.0.0",
  "description": "Multi-course learning platform for technology tutorials",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint src --ext .astro,.ts,.tsx",
