---
import '../styles/global.css';
import ReadingProgressIsland from '../components/ReadingProgressIsland';
import type { CourseDefinition } from '../courses/types';

interface Props {
  course: CourseDefinition;
  activeChapterId?: string;
  showSidebar?: boolean;
  backHref?: string;
}

const { course, activeChapterId, showSidebar = true, backHref = '/' } = Astro.props;
const activeChapter = activeChapterId ? course.chapters.find((chapter) => chapter.id === activeChapterId) : undefined;
const pageTitle = activeChapter ? `${activeChapter.title}｜${course.title}` : `${course.title}｜${course.subtitle}`;

function chapterHref(chapterId: string) {
  return `/course/${course.slug}/chapter/${chapterId}/`;
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={course.description} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
    <script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
    <script is:inline>
      function initKatex() {
        try {
          renderMathInElement(document.body, {
            delimiters: [
              {left: '$$', right: '$$', display: true},
              {left: '$', right: '$', display: false}
            ],
            throwOnError: false,
            trust: false,
            strict: false,
            macros: {
              '\\R': '\\mathbb{R}',
              '\\N': '\\mathbb{N}',
              '\\Z': '\\mathbb{Z}'
            }
          });
        } catch (e) {
          console.warn('KaTeX rendering error:', e);
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initKatex);
      } else {
        initKatex();
      }
    </script>
  </head>
  <body>
    <button class="mobile-menu" id="menuBtn" aria-label="打开或关闭章节目录">☰</button>
    <div class="app-shell">
      {showSidebar && (
        <aside class="sidebar" id="sidebar">
          <div class="sidebar-brand">
            <div class="sidebar-brand-mark">{course.icon}</div>
            <div>
              <div class="sidebar-brand-title">{course.title}</div>
              <div class="muted" style="font-size: 12px; margin-top: 2px;">{course.subtitle}</div>
            </div>
          </div>

          <div class="sidebar-search">
            <input
              type="text"
              id="chapterSearch"
              placeholder="搜索章节..."
              class="sidebar-search-input"
            />
          </div>

          <ReadingProgressIsland
            client:load
            chapterId={activeChapterId}
            chapterTitle={activeChapter?.navLabel}
            totalChapters={course.chapters.length}
            storageKey={course.storageKey}
            courseSlug={course.slug}
            chapters={course.chapters.map((chapter) => ({ id: chapter.id, label: chapter.navLabel }))}
          />

          <div class="sidebar-note">
            当前课程位于 <strong>{course.slug}</strong> 子目录。不同课程共用同一套 Astro 框架，但内容、互动和章节列表彼此独立。
          </div>

          <nav class="sidebar-group" aria-label={`${course.title} 章节目录`}>
            <div class="sidebar-group-title">章节目录</div>
            {course.groups.map((group) => (
              <div class="sidebar-group" style="margin-bottom: 10px;">
                <div class="sidebar-group-title" style="padding-left: 0; margin-bottom: 6px;">{group.label}</div>
                {group.chapters.map((chapter) => (
                  <a
                    class:list={["side-link", activeChapterId === chapter.id && 'active']}
                    data-ch={chapter.id}
                    href={chapterHref(chapter.id)}
                  >
                    <span class={`side-link-icon ${chapter.badgeClass}`}>{chapter.icon}</span>
                    <span class="side-link-title">{chapter.navLabel}</span>
                    <span class="side-link-check">✓</span>
                  </a>
                ))}
              </div>
            ))}
          </nav>

          <div class="sidebar-note" style="margin-top: 8px;">
            <a href={backHref} style="color: var(--accent); font-weight: 700;">← 返回课程目录</a>
          </div>
        </aside>
      )}

      <div class="main">
        <div class="progress"><div class="progress-bar" id="pbar"></div></div>
        <main class="content">
          <slot />
        </main>
      </div>
    </div>

    <button class="scroll-top" id="scrollTop" aria-label="返回顶部">↑</button>
    <script is:inline>
      const sidebar = document.getElementById('sidebar');
      const menuBtn = document.getElementById('menuBtn');
      const scrollTopBtn = document.getElementById('scrollTop');
      const progressBar = document.getElementById('pbar');

      const updateScrollProgress = () => {
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;

        if (progressBar) {
          progressBar.style.width = `${Math.min(pct, 100)}%`;
        }

        if (scrollTopBtn) {
          scrollTopBtn.classList.toggle('vis', scrollTop > 420);
        }
      };

      menuBtn?.addEventListener('click', () => {
        sidebar?.classList.toggle('open');
      });

      scrollTopBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      document.querySelectorAll('.side-link').forEach((link) => {
        link.addEventListener('click', () => {
          if (window.innerWidth <= 1080) {
            sidebar?.classList.remove('open');
          }
        });
      });

      window.addEventListener('scroll', updateScrollProgress, { passive: true });
      updateScrollProgress();

      // Chapter search functionality
      const searchInput = document.getElementById('chapterSearch');
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          document.querySelectorAll('.side-link').forEach((link) => {
            const title = link.querySelector('.side-link-title')?.textContent?.toLowerCase() || '';
            if (query === '' || title.includes(query)) {
              link.style.display = '';
            } else {
              link.style.display = 'none';
            }
          });
        });
      }
    </script>
  </body>
</html>
